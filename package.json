{
  "name": "pkstatus",
  "version": "0.12.2",
  "description": "Display PluralKit systems and their current status",
  "productName": "PKStatus",
  "homepage": "https://github.com/z0w13/pkstatus",
  "author": "Zowie <git@zowie.cx>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint --cache -c ./eslint.config.js \"./src*/**/*.{ts,js,cjs,mjs,vue}\"",
    "format": "prettier --write \"**/*.{js,ts,vue,scss,html,md,json}\"",
    "dev": "quasar dev",
    "release": "vite-node contrib/release.ts",
    "build": "quasar build",
    "prepare": "husky",
    "test:unit": "vitest",
    "test:unit:ci": "vitest run",
    "postinstall": "quasar prepare"
  },
  "lint-staged": {
    "src/**/*": [
      "prettier --list-different"
    ],
    "src/**/*.{ts,js,cjs,mjs,vue}": [
      "eslint"
    ]
  },
  "dependencies": {
    "@lumenpink/vue3-fitty": "^0.1.4",
    "@quasar/extras": "^1.16.17",
    "@types/markdown-it": "^14.1.2",
    "axios": "^1.6.8",
    "bottleneck": "^2.19.5",
    "dayjs": "^1.11.13",
    "markdown-it": "^14.1.0",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^3.2.1",
    "pkapi.js": "^7.3.2",
    "quasar": "^2.16.4",
    "register-service-worker": "^1.7.2",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@commander-js/extra-typings": "^12.0.1",
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@commitlint/types": "^19.0.3",
    "@quasar/app-vite": "2.2.0",
    "@quasar/icongenie": "^4.0.0",
    "@quasar/quasar-app-extension-testing-unit-vitest": "^1.1.0",
    "@types/node": "^20.12.5",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.5.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "chalk": "^5.4.1",
    "commander": "^12.0.0",
    "conventional-changelog-cli": "^4.1.0",
    "electron": "^29.2.0",
    "electron-builder": "^24.3.0",
    "eslint": "^9.24.0",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-vue": "^10.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.2",
    "prettier": "^3.5.3",
    "tmp-promise": "^3.0.3",
    "typescript": "^5.8.3",
    "vite-plugin-checker": "^0.9.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.2.2",
    "workbox-build": "^7.3.0",
    "workbox-cacheable-response": "^7.3.0",
    "workbox-core": "^7.3.0",
    "workbox-expiration": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0"
  },
  "engines": {
    "node": "^24 || ^22 || ^20 || ^18",
    "npm": ">= 6.13.4",
    "yarn": ">= 1.21.1"
  },
  "pnpm": {
    "overrides": {
      "vite": "5.4.18"
    }
  }
}
